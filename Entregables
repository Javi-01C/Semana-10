# ──────────────────────────────────────────────────────────────────────

def elegir_pivote(A, izq, der, estrategia):
    """
    Selecciona un pivote según la estrategia elegida y lo intercambia con A[der]
    para que la partición de Lomuto estándar funcione correctamente.
    """
    if estrategia == 'ultimo':
        return  # Ya está en la posición correcta (A[der])
        
    elif estrategia == 'aleatorio':
        idx_aleatorio = random.randint(izq, der)
        A[idx_aleatorio], A[der] = A[der], A[idx_aleatorio]
        
    elif estrategia == 'mediana3':
        medio = (izq + der) // 2
        # Ordenamos los tres elementos para hallar la mediana de manera manual
        if A[izq] > A[medio]: A[izq], A[medio] = A[medio], A[izq]
        if A[izq] > A[der]: A[izq], A[der] = A[der], A[izq]
        if A[medio] > A[der]: A[medio], A[der] = A[der], A[medio]
        # La mediana está en 'medio', la mandamos al extremo derecho
        A[medio], A[der] = A[der], A[medio]


def particionar_lomuto(A, izq, der):
    """
    Particiona A[izq..der] usando Lomuto.
    El pivote es A[der] (último elemento tras la preselección).
    Retorna el índice final del pivote.
    """
    # DECISIÓN: El pivote se ubica al final para tener un punto de referencia fijo durante el ciclo.
    # El puntero 'j' explora el arreglo buscando menores, mientras 'i' marca la frontera de los elementos procesados.
    pivote = A[der]
    i = izq - 1

    for j in range(izq, der):
        if A[j] <= pivote:
            i += 1
            A[i], A[j] = A[j], A[i]

    # Colocar el pivote en su posición definitiva
    A[i + 1], A[der] = A[der], A[i + 1]
    return i + 1


def quick_sort(A, izq=None, der=None, estrategia='ultimo'):
    """
    Quick Sort recursivo configurable sobre A[izq..der].
    Acepta las estrategias: 'ultimo', 'aleatorio' y 'mediana3'.
    """
    if izq is None:
        izq = 0
    if der is None:
        der = len(A) - 1

    if izq < der:
        # Colocamos el pivote ideal en la posición de la derecha antes de particionar
        elegir_pivote(A, izq, der, estrategia)
        p = particionar_lomuto(A, izq, der)
        
        # Llamadas recursivas excluyendo el pivote ya ordenado
        quick_sort(A, izq, p - 1, estrategia)
        quick_sort(A, p + 1, der, estrategia)


