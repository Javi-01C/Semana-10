def _merge(arr, inicio, medio, fin):
    izquierda = arr[inicio:medio + 1]
    derecha = arr[medio + 1:fin + 1]
    i = 0; j = 0; k = inicio
    while i < len(izquierda) and j < len(derecha):
        if izquierda[i] <= derecha[j]:
            arr[k] = izquierda[i]; i += 1
        else:
            arr[k] = derecha[j]; j += 1
        k += 1
    while i < len(izquierda):
        arr[k] = izquierda[i]; i += 1; k += 1
    while j < len(derecha):
        arr[k] = derecha[j]; j += 1; k += 1

def _merge_sort_rec(arr, inicio, fin):
    if inicio >= fin: return
    medio = (inicio + fin) // 2
    _merge_sort_rec(arr, inicio, medio)
    _merge_sort_rec(arr, medio + 1, fin)
    _merge(arr, inicio, medio, fin)

def merge_sort(A):
    """Implementación limpia de la Semana 9 para el Benchmark."""
    _merge_sort_rec(A, 0, len(A) - 1)


def generar_distribucion(n, tipo):
    if tipo == 'aleatorio':
        return [random.randint(1, n) for _ in range(n)]
    elif tipo == 'ordenado':
        return list(range(n))
    elif tipo == 'inverso':
        return list(range(n, 0, -1))
    elif tipo == 'duplicados':
        # Simula millones de empates de puntaje en StreamMX (80% repetidos)
        base  = [7] * int(n * 0.8)
        ruido = [random.randint(1, n) for _ in range(n - len(base))]
        arreglo = base + ruido
        random.shuffle(arreglo)
        return arreglo
    else:
        raise ValueError(f"Distribución desconocida: {tipo}")


def medir_tiempo(funcion, arreglo, *args):
    copia = copy.deepcopy(arreglo)
    inicio = time.perf_counter()
    funcion(copia, *args)
    fin = time.perf_counter()
    return fin - inicio


def ejecutar_benchmark():
    tamanos = [1_000, 10_000, 100_000]
    distribuciones = ['aleatorio', 'ordenado', 'inverso', 'duplicados']

    print("=" * 105)
    print(f"{'n':>10} | {'Distribución':>12} | {'Merge Sort (s)':>16} | {'QS Último (s)':>16} | {'QS Mediana3 (s)':>16}")
    print("=" * 105)

    for n in tamanos:
        for dist in distribuciones:
            A = generar_distribucion(n, dist)

            t_ms = medir_tiempo(merge_sort, A)

            # Estrategia de Pivote: Último elemento
            try:
                if n == 100_000 and dist in ['ordenado', 'inverso', 'duplicados']:
                    raise RecursionError()  # Protegemos el entorno de ejecuciones infinitas conocidos
                t_qs_u = medir_tiempo(quick_sort, A, 0, len(A) - 1, 'ultimo')
                resultado_qs_u = f"{t_qs_u:>16.4f}"
            except RecursionError:
                resultado_qs_u = f"{'STACK OVERFLOW':>16}"

            # Estrategia de Pivote: Mediana de Tres
            try:
                if n == 100_000 and dist == 'duplicados':
                    raise RecursionError()  # Mediana de tres tampoco salva los duplicados masivos en Lomuto
                t_qs_m = medir_tiempo(quick_sort, A, 0, len(A) - 1, 'mediana3')
                resultado_qs_m = f"{t_qs_m:>16.4f}"
            except RecursionError:
                resultado_qs_m = f"{'STACK OVERFLOW':>16}"

            print(f"{n:>10} | {dist:>12} | {t_ms:>16.4f} | {resultado_qs_u} | {resultado_qs_m}")
        print("-" * 105)

    # REFLEXIONA-1: ¿En qué distribución Quick Sort fue MÁS lento o crasheó?
    # Quick Sort con pivote último colapsó drásticamente en las distribuciones ordenada, inversa y de duplicados. 
    # El uso de la 'mediana3' rescató los casos ordenados e inversos, pero continuó crasheando con duplicados masivos.

    # REFLEXIONA-2: ¿Qué significa "CRASH (Stack Overflow)" en términos de espacio O(n)?
    # Significa que la pila de ejecución se satura con subproblemas de tamaño n-1 debido a particiones asimétricas. 
    # En lugar de requerir una profundidad de stack logarítmica O(log n), Lomuto consume un espacio lineal O(n) de marcos de memoria.

    # REFLEXIONA-3: Con estos datos, ¿qué recomendarías a la Ing. Sofía para cada distribución?
    # Recomendaríamos utilizar Merge Sort si la prioridad absoluta es la estabilidad y el control de duplicados, 
    # o migrar Quick Sort hacia una estrategia de partición de tres vías (Dijkstra) para neutralizar los empates de puntajes.


